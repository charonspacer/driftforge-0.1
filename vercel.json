{
  "version": 2,
  "builds": [
    {
      "src": "api/*.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/post",
      "dest": "/api/post.mjs"
    },
    {
      "src": "/api/valence",
      "dest": "/api/valence.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}